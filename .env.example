# ── Misconfig Index — environment template ─────────────────────────────────────
# Copy this file to .env and fill in the values before running.
#
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (SQLite — no extra setup required):
DATABASE_URL=sqlite:///./misconfig_index.db

# Production (PostgreSQL — docker-compose builds the URL automatically from
# the POSTGRES_* vars below, so you don't need to set DATABASE_URL manually).
# If running outside Docker, uncomment and fill in this line instead:
# DATABASE_URL=postgresql://misconfig:changeme@localhost:5432/misconfig_index

# PostgreSQL credentials — used by the db service in docker-compose
POSTGRES_USER=misconfig
POSTGRES_PASSWORD=changeme          # ← CHANGE THIS before deploying!
POSTGRES_DB=misconfig_index

# ── API server ────────────────────────────────────────────────────────────────
ENVIRONMENT=development             # development | production
API_WORKERS=2                       # uvicorn workers (production: ~2× CPU cores)

# ── CORS ─────────────────────────────────────────────────────────────────────
# "*" allows all origins. In production, restrict to your domain:
# CORS_ORIGINS=https://misconfig.dev,https://www.misconfig.dev
CORS_ORIGINS=*

# ── Web / nginx ───────────────────────────────────────────────────────────────
WEB_PORT=80                         # host port nginx binds to (80 or 443)

# ── Optional integrations ─────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here
